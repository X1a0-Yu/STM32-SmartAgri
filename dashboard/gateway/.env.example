# Required local hardware identity
SMARTAGRI_GATEWAY_DEVICE_ID=greenhouse-001
SMARTAGRI_GATEWAY_ID=gateway-greenhouse-001
SMARTAGRI_GATEWAY_SERIAL_PORT=COM6
SMARTAGRI_GATEWAY_SERIAL_BAUD=19200

# EMQX: TLS-only. Never set this to false in production.
SMARTAGRI_GATEWAY_MQTT_HOST=emqx.example.com
SMARTAGRI_GATEWAY_MQTT_PORT=8883
SMARTAGRI_GATEWAY_MQTT_USERNAME=replace-with-gateway-credential
SMARTAGRI_GATEWAY_MQTT_PASSWORD=replace-with-secret
# Set when the broker uses a private CA; leave empty for a public CA.
SMARTAGRI_GATEWAY_MQTT_CA_PATH=

SMARTAGRI_GATEWAY_SPOOL_PATH=./data/gateway-spool.sqlite3
SMARTAGRI_GATEWAY_SPOOL_MAX_ROWS=10000
SMARTAGRI_GATEWAY_COMMAND_TIMEOUT=5
