# Copy this file to .env on the server; never commit actual values.
POSTGRES_DB=smartagri
POSTGRES_USER=smartagri
POSTGRES_PASSWORD=replace-with-long-random-password
FLASK_SECRET_KEY=replace-with-long-random-secret

# Existing EMQX endpoint. TLS must be enabled and its CA supplied below.
MQTT_HOST=emqx.x1a0yu.top
MQTT_PORT=8883
MQTT_BACKEND_USERNAME=smartagri-backend
MQTT_BACKEND_PASSWORD=replace-with-backend-secret
MQTT_CA_FILE=/absolute/path/to/emqx-ca.pem
